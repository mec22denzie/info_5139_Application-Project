rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users - authenticated users can read their own, admins can read all
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Products - anyone authenticated can read, donors can write
    match /products/{productId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    // Orders - authenticated users can read/write their own
    match /orders/{orderId} {
      allow read, write: if request.auth != null;
    }

    // Carts - authenticated users can read/write their own
    match /carts/{cartId} {
      allow read, write: if request.auth != null;
    }

    // Notifications - users can read their own, system can write
    match /notifications/{notifId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }

    // System Logs - admins can read, system can write
    match /systemLogs/{logId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
    }

    // Reports - authenticated can create, admins can read/update
    match /reports/{reportId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }

    // Admin actions
    match /adminActions/{actionId} {
      allow read, write: if request.auth != null;
    }

    // User sub-collections (addresses etc)
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
